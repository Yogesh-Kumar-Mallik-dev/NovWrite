model Battle {
  id String @id @default(cuid())

  historicalEventId String          @unique
  historicalEvent   HistoricalEvent @relation(fields: [historicalEventId], references: [id])

  conflictType ConflictType
  outcome      BattleOutcome

  description String?

  duration Int?

  warId String?
  war   War?    @relation(fields: [warId], references: [id])

  sides BattleSide[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conflictType])
  @@index([outcome])
  @@index([warId])
}

model BattleSide {
  id String @id @default(cuid())

  battleId String
  battle   Battle @relation(fields: [battleId], references: [id])

  name String?

  side Int

  outcome BattleOutcome

  participants BattleParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([battleId, side])
  @@index([battleId])
}

model BattleParticipant {
  id String @id @default(cuid())

  battleSideId String
  battleSide   BattleSide @relation(fields: [battleSideId], references: [id])

  characterId String?
  character   Characters? @relation(fields: [characterId], references: [id])

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  role BattleRole

  commander Boolean @default(false)

  casualties Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([battleSideId])
  @@index([characterId])
  @@index([organizationId])
}

model Calendar {
  id String @id @default(cuid())

  name String @unique

  monthsPerYear Int @default(12)
  daysPerMonth  Int @default(35)
  daysPerWeek   Int @default(7)

  pivotYear Int @default(0)

  description String?

  months Json

  weekdays Json

  eras CalendarEra[]

  festivals Festival[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CalendarEra {
  id String @id @default(cuid())

  calendarId String
  calendar   Calendar @relation(fields: [calendarId], references: [id])

  name String

  startYear Json
  endYear   Json?

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([calendarId])
}

model Festival {
  id String @id @default(cuid())

  calendarId String
  calendar   Calendar @relation(fields: [calendarId], references: [id])

  name String

  date Json

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([calendarId])
}

model Characters {
  id          String             @id @default(cuid())
  name        String
  dateOfBirth Json?
  species     CharacterSpecies[]
  basePower   Int                @default(0)

  spiritRootId String
  spiritRoot   SpiritRoots @relation(fields: [spiritRootId], references: [id])

  inventory CharacterInventory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizations CharacterOrganization[]

  foundedOrganizations Organization[] @relation("OrganizationFounder")

  leadingOrganizations Organization[] @relation("OrganizationLeader")

  locations CharacterLocation[]

  relations CharacterRelations[] @relation("SourceCharacter")
  relatedTo CharacterRelations[] @relation("TargetCharacter")

  titles        CharacterTitle[]
  grantedTitles CharacterTitle[] @relation("TitleGrantedByCharacter")

  historicalEvents      CharacterHistoricalEvent[]
  characterCultivations CharacterCultivation[]

  occupations        CharacterOccupation[]
  grantedOccupations CharacterOccupation[] @relation("OccupationGrantedByCharacter")

  crafts CharacterCraft[]

  characterVersions  CharacterVersion[]
  battleParticipants BattleParticipant[]
}

model CharacterVersion {
  id String @id @default(cuid())

  characterId String
  character   Characters @relation(fields: [characterId], references: [id])

  version Int

  title String?

  description String?

  createdAt DateTime @default(now())
}

model CharacterInventory {
  id String @id @default(cuid())

  characterId String
  character   Characters @relation(fields: [characterId], references: [id])

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  quantity Int     @default(1)
  equipped Boolean @default(false)

  obtainedAt Json?

  lostAt Json?
  reason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([characterId])
}

model CharacterCultivation {
  id String @id @default(cuid())

  characterId String
  character   Characters @relation(fields: [characterId], references: [id], onDelete: Cascade)

  path Cultivation_Path

  majorRealmId String
  majorRealm   MajorRealm @relation(fields: [majorRealmId], references: [id])

  minorRealmId String
  minorRealm   MinorRealm @relation(fields: [minorRealmId], references: [id])

  currentEnergy Int?
  peakReached   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([characterId, path])
}

model CharacterRelations {
  id String @id @default(cuid())

  sourceCharacterId String
  targetCharacterId String

  relationshipType RelationshipType

  startDate Json?
  endDate   Json?

  description String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceCharacter Characters @relation("SourceCharacter", fields: [sourceCharacterId], references: [id])
  targetCharacter Characters @relation("TargetCharacter", fields: [targetCharacterId], references: [id])

  @@index([sourceCharacterId])
  @@index([targetCharacterId])
}

model CharacterOrganization {
  id String @id @default(cuid())

  characterId    String
  organizationId String

  character    Characters   @relation(fields: [characterId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  role OrganizationRole

  contributionPoints Int?
  reputation         Int?

  joinedAt Json?
  leftAt   Json?

  reason String?

  isCurrent Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([characterId, organizationId, role, isCurrent])
  @@index([characterId])
  @@index([organizationId])
  @@index([role])
  @@index([isCurrent])
}

model Recipe {
  id String @id @default(cuid())

  name String @unique

  category RecipeCategory

  description String?

  occupationId String
  occupation   Occupation @relation(fields: [occupationId], references: [id])

  resultItemId String
  resultItem   Item   @relation("RecipeResult", fields: [resultItemId], references: [id])

  requiredRealm Qi_MajorRealm?

  craftingTime Int?

  ingredients RecipeIngredient[]

  crafts CharacterCraft[]

  formation Formation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([occupationId])
}

model RecipeIngredient {
  id String @id @default(cuid())

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id])

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  quantity Int @default(1)

  optional Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([recipeId, itemId])
  @@index([recipeId])
  @@index([itemId])
}

model CharacterCraft {
  id String @id @default(cuid())

  characterId String
  character   Characters @relation(fields: [characterId], references: [id])

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id])

  historicalEventId String?
  historicalEvent   HistoricalEvent? @relation(fields: [historicalEventId], references: [id])

  quantity Int @default(1)

  result CraftResult

  craftedAt Json?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([characterId])
  @@index([recipeId])
  @@index([historicalEventId])
}

model Formation {
  id String @id @default(cuid())

  recipeId String @unique
  recipe   Recipe @relation(fields: [recipeId], references: [id])

  category FormationCategory

  radius Int?

  minimumParticipants Int?

  maximumParticipants Int?

  duration Int?

  effect String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model SpiritRoots {
  id String @id @default(cuid())

  elements Elements[]

  breakthroughMultiplier Int?
  basePowerMultiplier    Int?

  description String?

  characters Characters[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Physique {
  id String @id @default(cuid())

  name  String
  grade Grade

  powerMultiplier Int?
  breakthrough    Int?

  bodyRealmbreakthroughChance Int?
  QiRealmbreakthroughChance   Int?
  soulRealmbreakthroughChance Int?

  specialProperty String?
  description     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bloodline {
  id String @id @default(cuid())

  name  String
  grade Grade

  powerMultiplier Int?
  breakthrough    Int?

  progenyChance Int?

  bodyRealmbreakthroughChance Int?
  QiRealmbreakthroughChance   Int?
  soulRealmbreakthroughChance Int?

  specialProperty String?
  description     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

