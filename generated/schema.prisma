model HistoricalEvent {
  id String @id @default(cuid())

  title String @unique

  type  HistoricalEventType
  scale HistoricalEventScale

  description String?
  crafts      CharacterCraft[]
  date        Json

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])

  parentEventId String?
  parentEvent   HistoricalEvent? @relation("HistoricalEventHierarchy", fields: [parentEventId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  subEvents HistoricalEvent[] @relation("HistoricalEventHierarchy")

  characterEvents    CharacterHistoricalEvent[]
  organizationEvents OrganizationHistoricalEvent[]
  locationEvents     LocationHistoricalEvent[]
  itemEvents         ItemHistoricalEvent[]

  titles CharacterTitle[]
  war    War?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  battle Battle?

  occupations CharacterOccupation[]

  @@index([type])
  @@index([scale])
  @@index([locationId])
  @@index([parentEventId])
}

model CharacterHistoricalEvent {
  id String @id @default(cuid())

  characterId String
  eventId     String

  character Characters      @relation(fields: [characterId], references: [id])
  event     HistoricalEvent @relation(fields: [eventId], references: [id])

  role String?

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([characterId, eventId])
  @@index([characterId])
  @@index([eventId])
}

model OrganizationHistoricalEvent {
  id String @id @default(cuid())

  organizationId String
  eventId        String

  organization Organization    @relation(fields: [organizationId], references: [id])
  event        HistoricalEvent @relation(fields: [eventId], references: [id])

  role String?

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, eventId])
  @@index([organizationId])
  @@index([eventId])
}

model LocationHistoricalEvent {
  id String @id @default(cuid())

  locationId String
  eventId    String

  location Location        @relation(fields: [locationId], references: [id])
  event    HistoricalEvent @relation(fields: [eventId], references: [id])

  role String?

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locationId, eventId])
  @@index([locationId])
  @@index([eventId])
}

model ItemHistoricalEvent {
  id String @id @default(cuid())

  itemId  String
  eventId String

  item  Item            @relation(fields: [itemId], references: [id])
  event HistoricalEvent @relation(fields: [eventId], references: [id])

  role String?

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([itemId, eventId])
  @@index([itemId])
  @@index([eventId])
}

model Item {
  id String @id @default(cuid())

  name  String
  grade Grade

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  characterInventories CharacterInventory[]
  historicalEvents     ItemHistoricalEvent[]
  recipeResult         Recipe[]              @relation("RecipeResult")

  recipeIngredients RecipeIngredient[]
  weapon            Weapon?
  armor             Armor?
  pill              Pill?
  talisman          Talisman?
  artifact          Artifact?
  treasure          Treasure?
  secretScroll      SecretScroll?
  material          Material?
}

model Weapon {
  id String @id @default(cuid())

  itemId String @unique
  item   Item   @relation(fields: [itemId], references: [id])

  weaponType WeaponType

  attackPower   Int?
  durability    Int?
  element       Elements?
  requiredRealm Qi_MajorRealm?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Armor {
  id String @id @default(cuid())

  itemId String @unique
  item   Item   @relation(fields: [itemId], references: [id])

  armorType ArmorType

  defense    Int?
  durability Int?
  element    Elements?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pill {
  id String @id @default(cuid())

  itemId String @unique
  item   Item   @relation(fields: [itemId], references: [id])

  pillType PillType

  powerGain          Int?
  breakthroughChance Int?
  toxicity           Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Talisman {
  id String @id @default(cuid())

  itemId String @unique
  item   Item   @relation(fields: [itemId], references: [id])

  catagory TalismanType
  uses     Int?
  element  Elements?
  effect   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Artifact {
  id String @id @default(cuid())

  itemId String @unique
  item   Item   @relation(fields: [itemId], references: [id])

  category ArtifactCategory

  passiveEffect String?
  activeEffect  String?

  durability Int?

  bound          Boolean @default(false)
  rechargeable   Boolean @default(false)
  growthArtifact Boolean @default(false)

  uses Int?

  requiredRealm Qi_MajorRealm?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model Treasure {
  id String @id @default(cuid())

  itemId String @unique
  item   Item   @relation(fields: [itemId], references: [id])

  category TreasureCategory

  passiveEffect String?
  activeEffect  String?

  consumable Boolean @default(false)
  sentient   Boolean @default(false)
  unique     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model SecretScroll {
  id String @id @default(cuid())

  itemId String @unique
  item   Item   @relation(fields: [itemId], references: [id])

  knowledgeType SecretKnowledgeType
  knowledgeId   String

  oneTimeUse Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Material {
  id String @id @default(cuid())

  itemId String @unique
  item   Item   @relation(fields: [itemId], references: [id])

  type   MaterialType
  source MaterialSource

  purity Int?

  renewable Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([source])
}

model Location {
  id String @id @default(cuid())

  name String @unique

  type LocationType

  description String?

  parentLocationId String?
  parentLocation   Location? @relation("LocationHierarchy", fields: [parentLocationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  childLocations Location[] @relation("LocationHierarchy")

  residents        CharacterLocation[]
  timeTravel       Boolean                   @default(false)
  historicalEvents LocationHistoricalEvent[]

  events HistoricalEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([parentLocationId])
}

model CharacterLocation {
  id String @id @default(cuid())

  characterId String
  locationId  String

  character Characters @relation(fields: [characterId], references: [id])
  location  Location   @relation(fields: [locationId], references: [id])

  arrivedAt Json?

  leftAt Json?

  reason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([characterId])
  @@index([locationId])
  @@index([leftAt])
}

model Occupation {
  id String @id @default(cuid())

  name    String   @unique
  aliases String[]

  description String?

  parentOccupationId String?
  parentOccupation   Occupation? @relation("OccupationHierarchy", fields: [parentOccupationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  childOccupations Occupation[] @relation("OccupationHierarchy")

  practitioners CharacterOccupation[]
  recipes       Recipe[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentOccupationId])
}

model CharacterOccupation {
  id String @id @default(cuid())

  characterId  String
  occupationId String

  character  Characters @relation(fields: [characterId], references: [id])
  occupation Occupation @relation(fields: [occupationId], references: [id])

  grade Grade?

  grantedByCharacterId String?
  grantedByCharacter   Characters? @relation("OccupationGrantedByCharacter", fields: [grantedByCharacterId], references: [id])

  grantedByOrganizationId String?
  grantedByOrganization   Organization? @relation("OccupationGrantedByOrganization", fields: [grantedByOrganizationId], references: [id])

  historicalEventId String?
  historicalEvent   HistoricalEvent? @relation(fields: [historicalEventId], references: [id])

  acquiredAt Json?
  lostAt     Json?

  reason String?

  isCurrent Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([characterId, occupationId, isCurrent])
  @@index([characterId])
  @@index([occupationId])
  @@index([historicalEventId])
  @@index([grantedByCharacterId])
  @@index([grantedByOrganizationId])
  @@index([isCurrent])
}

model Organization {
  id String @id @default(cuid())

  name    String   @unique
  aliases String[]

  type OrganizationType

  description String?

  founderId String?
  founder   Characters? @relation("OrganizationFounder", fields: [founderId], references: [id])

  leaderId String?
  leader   Characters? @relation("OrganizationLeader", fields: [leaderId], references: [id])

  parentOrganizationId String?
  parentOrganization   Organization? @relation("OrganizationHierarchy", fields: [parentOrganizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  subOrganizations Organization[] @relation("OrganizationHierarchy")

  foundedAt   Json?
  dissolvedAt Json?

  wars             WarParticipant[]
  members          CharacterOrganization[]
  historicalEvents OrganizationHistoricalEvent[]
  grantedTitles    CharacterTitle[]              @relation("TitleGrantedByOrganization")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  battleParticipants BattleParticipant[]
  grantedOccupations CharacterOccupation[] @relation("OccupationGrantedByOrganization")

  @@index([type])
  @@index([leaderId])
  @@index([founderId])
  @@index([parentOrganizationId])
}

model MajorRealm {
  id String @id @default(cuid())

  path Cultivation_Path

  qiRealm   Qi_MajorRealm?
  bodyRealm Body_MajorRealm?
  soulRealm Soul_MajorRealm?

  power              Int?
  description        String?
  lifespan           Int?
  requiredEnergy     Int?
  breakthroughChance Float?

  minorRealms MinorRealm[]
  cultivation CharacterCultivation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MinorRealm {
  id String @id @default(cuid())

  majorRealmId String

  majorRealm MajorRealm @relation(fields: [majorRealmId], references: [id], onDelete: Cascade)

  realm Minor_Realm

  power              Int?
  description        String?
  breakthroughChance Float?

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  characterCultivations CharacterCultivation[]

  @@unique([majorRealmId, realm])
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

model Species {
  id String @id @default(cuid())

  name    String   @unique
  aliases String[]

  description String?

  parentSpeciesId String?
  parentSpecies   Species? @relation("SpeciesHierarchy", fields: [parentSpeciesId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  childSpecies Species[] @relation("SpeciesHierarchy")

  grade Grade?

  averageLifespan Int?
  maximumLifespan Int?

  extinct  Boolean @default(false)
  playable Boolean @default(true)

  members CharacterSpecies[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentSpeciesId])
  @@index([grade])
  @@index([extinct])
}

model CharacterSpecies {
  id String @id @default(cuid())

  characterId String
  speciesId   String

  character Characters @relation(fields: [characterId], references: [id])
  species   Species    @relation(fields: [speciesId], references: [id])

  acquiredAt Json?
  lostAt     Json?

  reason String?

  isCurrent Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([characterId, speciesId, isCurrent])
  @@index([characterId])
  @@index([speciesId])
  @@index([isCurrent])
}

model CultivationTechnique {
  id String @id @default(cuid())

  name  String
  grade Grade

  compatiblePaths CultivationPath[]

  requiredQiRealm   Qi_MajorRealm?
  requiredBodyRealm Body_MajorRealm?
  requiredSoulRealm Soul_MajorRealm?

  powerMultiplier   Int?
  cultivationSpeed  Int?
  breakthroughBonus Int?

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FightingTechnique {
  id String @id @default(cuid())

  name  String
  grade Grade

  type FightingTechniqueType

  compatiblePaths CultivationPath[]

  requiredQiRealm   Qi_MajorRealm?
  requiredBodyRealm Body_MajorRealm?
  requiredSoulRealm Soul_MajorRealm?

  qiCost      Int?
  staminaCost Int?
  soulCost    Int?

  powerMultiplier Int?

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Title {
  id String @id @default(cuid())

  name    String   @unique
  aliases String[]

  type TitleType

  description String?

  prestige Int @default(0)

  holders CharacterTitle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([prestige])
}

model CharacterTitle {
  id String @id @default(cuid())

  characterId String
  titleId     String

  character Characters @relation(fields: [characterId], references: [id])
  title     Title      @relation(fields: [titleId], references: [id])

  grantedByCharacterId String?
  grantedByCharacter   Characters? @relation("TitleGrantedByCharacter", fields: [grantedByCharacterId], references: [id])

  grantedByOrganizationId String?
  grantedByOrganization   Organization? @relation("TitleGrantedByOrganization", fields: [grantedByOrganizationId], references: [id])

  historicalEventId String?
  historicalEvent   HistoricalEvent? @relation(fields: [historicalEventId], references: [id])

  grantedAt Json?
  revokedAt Json?

  reason String?

  isCurrent Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([characterId, titleId, isCurrent])
  @@index([characterId])
  @@index([titleId])
  @@index([historicalEventId])
  @@index([grantedByCharacterId])
  @@index([grantedByOrganizationId])
  @@index([isCurrent])
}

model War {
  id String @id @default(cuid())

  historicalEventId String          @unique
  historicalEvent   HistoricalEvent @relation(fields: [historicalEventId], references: [id])

  type    WarType
  outcome WarOutcome

  cause  String?
  result String?

  startedAt Json
  endedAt   Json?

  participants WarParticipant[]

  battles Battle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([outcome])
}

model WarParticipant {
  id String @id @default(cuid())

  warId String
  war   War    @relation(fields: [warId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  side Int

  role WarRole

  joinedAt Json?
  leftAt   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([warId, organizationId])
  @@index([warId])
  @@index([organizationId])
}
