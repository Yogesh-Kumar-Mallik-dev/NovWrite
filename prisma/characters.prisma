model Characters {
  id          String             @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  dateOfBirth WorldDate?
  species     CharacterSpecies[]
  basePower   Int                @default(0)

  spiritRootId String      @db.ObjectId
  spiritRoot   SpiritRoots @relation(fields: [spiritRootId], references: [id])

  inventory CharacterInventory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizations CharacterOrganization[]

  foundedOrganizations Organization[] @relation("OrganizationFounder")

  leadingOrganizations Organization[] @relation("OrganizationLeader")

  locations CharacterLocation[]

  relations CharacterRelations[] @relation("SourceCharacter")
  relatedTo CharacterRelations[] @relation("TargetCharacter")

  titles        CharacterTitle[]
  grantedTitles CharacterTitle[] @relation("TitleGrantedByCharacter")

  historicalEvents      CharacterHistoricalEvent[]
  characterCultivations CharacterCultivation[]

  occupations        CharacterOccupation[]
  grantedOccupations CharacterOccupation[] @relation("OccupationGrantedByCharacter")

  crafts CharacterCraft[]

  characterVersions  CharacterVersion[]
  battleParticipants BattleParticipant[]
}

model CharacterVersion {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  characterId String     @db.ObjectId
  character   Characters @relation(fields: [characterId], references: [id])

  version Int

  title String?

  description String?

  createdAt DateTime @default(now())
}

model CharacterInventory {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  characterId String     @db.ObjectId
  character   Characters @relation(fields: [characterId], references: [id])

  itemId String @db.ObjectId
  item   Item   @relation(fields: [itemId], references: [id])

  quantity Int     @default(1)
  equipped Boolean @default(false)

  obtainedAt WorldDate?

  lostAt WorldDate?
  reason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([characterId])
}

model CharacterCultivation {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  characterId String     @db.ObjectId
  character   Characters @relation(fields: [characterId], references: [id], onDelete: Cascade)

  path Cultivation_Path

  majorRealmId String     @db.ObjectId
  majorRealm   MajorRealm @relation(fields: [majorRealmId], references: [id])

  minorRealmId String     @db.ObjectId
  minorRealm   MinorRealm @relation(fields: [minorRealmId], references: [id])

  currentEnergy Int?
  peakReached   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([characterId, path])
}

model CharacterRelations {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  sourceCharacterId String @db.ObjectId
  targetCharacterId String @db.ObjectId

  relationshipType RelationshipType

  startDate WorldDate?
  endDate   WorldDate?

  description String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceCharacter Characters @relation("SourceCharacter", fields: [sourceCharacterId], references: [id])
  targetCharacter Characters @relation("TargetCharacter", fields: [targetCharacterId], references: [id])

  @@index([sourceCharacterId])
  @@index([targetCharacterId])
}
