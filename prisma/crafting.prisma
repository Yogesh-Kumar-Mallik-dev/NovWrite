model Recipe {
  id String @id @default(cuid())

  name String @unique

  category RecipeCategory

  description String?

  occupationId String
  occupation   Occupation @relation(fields: [occupationId], references: [id])

  resultItemId String
  resultItem   Item   @relation("RecipeResult", fields: [resultItemId], references: [id])

  requiredRealm Qi_MajorRealm?

  craftingTime Int?

  ingredients RecipeIngredient[]

  crafts CharacterCraft[]

  formation Formation?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([occupationId])
}

model RecipeIngredient {
  id String @id @default(cuid())

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id])

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  quantity Int @default(1)

  optional Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([recipeId, itemId])
  @@index([recipeId])
  @@index([itemId])
}

model CharacterCraft {
  id String @id @default(cuid())

  characterId String
  character   Characters @relation(fields: [characterId], references: [id])

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id])

  historicalEventId String?
  historicalEvent   HistoricalEvent? @relation(fields: [historicalEventId], references: [id])

  quantity Int @default(1)

  result CraftResult

  craftedAt Json?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([characterId])
  @@index([recipeId])
  @@index([historicalEventId])
}

model Formation {
  id String @id @default(cuid())

  recipeId String @unique
  recipe   Recipe @relation(fields: [recipeId], references: [id])

  category FormationCategory

  radius Int?

  minimumParticipants Int?

  maximumParticipants Int?

  duration Int?

  effect String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}
