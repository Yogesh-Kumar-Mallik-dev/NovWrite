model Item {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name  String
  grade Grade

  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  characterInventories CharacterInventory[]
  historicalEvents     ItemHistoricalEvent[]
  recipeResult         Recipe[]              @relation("RecipeResult")

  recipeIngredients RecipeIngredient[]
  weapon            Weapon?
  armor             Armor?
  pill              Pill?
  talisman          Talisman?
  artifact          Artifact?
  treasure          Treasure?
  secretScroll      SecretScroll?
  material          Material?
}

model Weapon {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  itemId String @unique @db.ObjectId
  item   Item   @relation(fields: [itemId], references: [id])

  weaponType WeaponType

  attackPower   Int?
  durability    Int?
  element       Elements?
  requiredRealm Qi_MajorRealm?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Armor {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  itemId String @unique @db.ObjectId
  item   Item   @relation(fields: [itemId], references: [id])

  armorType ArmorType

  defense    Int?
  durability Int?
  element    Elements?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pill {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  itemId String @unique @db.ObjectId
  item   Item   @relation(fields: [itemId], references: [id])

  pillType PillType

  powerGain          Int?
  breakthroughChance Int?
  toxicity           Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Talisman {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  itemId String @unique @db.ObjectId
  item   Item   @relation(fields: [itemId], references: [id])

  uses    Int?
  element Elements?
  effect  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Artifact {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  itemId String @unique @db.ObjectId
  item   Item   @relation(fields: [itemId], references: [id])

  category ArtifactCategory

  passiveEffect String?
  activeEffect  String?

  durability Int?

  bound          Boolean @default(false)
  rechargeable   Boolean @default(false)
  growthArtifact Boolean @default(false)

  uses Int?

  requiredRealm Qi_MajorRealm?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model Treasure {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  itemId String @unique @db.ObjectId
  item   Item   @relation(fields: [itemId], references: [id])

  category TreasureCategory

  passiveEffect String?
  activeEffect  String?

  consumable Boolean @default(false)
  sentient   Boolean @default(false)
  unique     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model SecretScroll {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  itemId String @unique @db.ObjectId
  item   Item   @relation(fields: [itemId], references: [id])

  knowledgeType SecretKnowledgeType
  knowledgeId   String              @db.ObjectId

  oneTimeUse Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Material {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  itemId String @unique @db.ObjectId
  item   Item   @relation(fields: [itemId], references: [id])

  type   MaterialType
  source MaterialSource

  purity Int?

  renewable Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([source])
}
