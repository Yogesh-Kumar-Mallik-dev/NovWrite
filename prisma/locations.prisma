model Location {
  id String @id @default(cuid())

  name String @unique

  type LocationType

  description String?

  parentLocationId String?
  parentLocation   Location? @relation("LocationHierarchy", fields: [parentLocationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  childLocations Location[] @relation("LocationHierarchy")

  residents        CharacterLocation[]
  timeTravel       Boolean                   @default(false)
  historicalEvents LocationHistoricalEvent[]

  events HistoricalEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([parentLocationId])
}

model CharacterLocation {
  id String @id @default(cuid())

  characterId String
  locationId  String

  character Characters @relation(fields: [characterId], references: [id])
  location  Location   @relation(fields: [locationId], references: [id])

  arrivedAt Json?

  leftAt Json?

  reason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([characterId])
  @@index([locationId])
  @@index([leftAt])
}
