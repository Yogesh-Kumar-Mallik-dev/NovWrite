model Occupation {
  id String @id @default(cuid())

  name    String   @unique
  aliases String[]

  description String?

  parentOccupationId String?
  parentOccupation   Occupation? @relation("OccupationHierarchy", fields: [parentOccupationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  childOccupations Occupation[] @relation("OccupationHierarchy")

  practitioners CharacterOccupation[]
  recipes       Recipe[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentOccupationId])
}

model CharacterOccupation {
  id String @id @default(cuid())

  characterId  String
  occupationId String

  character  Characters @relation(fields: [characterId], references: [id])
  occupation Occupation @relation(fields: [occupationId], references: [id])

  grade Grade?

  grantedByCharacterId String?
  grantedByCharacter   Characters? @relation("OccupationGrantedByCharacter", fields: [grantedByCharacterId], references: [id])

  grantedByOrganizationId String?
  grantedByOrganization   Organization? @relation("OccupationGrantedByOrganization", fields: [grantedByOrganizationId], references: [id])

  historicalEventId String?
  historicalEvent   HistoricalEvent? @relation(fields: [historicalEventId], references: [id])

  acquiredAt Json?
  lostAt     Json?

  reason String?

  isCurrent Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([characterId, occupationId, isCurrent])
  @@index([characterId])
  @@index([occupationId])
  @@index([historicalEventId])
  @@index([grantedByCharacterId])
  @@index([grantedByOrganizationId])
  @@index([isCurrent])
}
