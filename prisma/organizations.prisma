model Organization {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name    String   @unique
  aliases String[]

  type OrganizationType

  description String?

  founderId String?     @db.ObjectId
  founder   Characters? @relation("OrganizationFounder", fields: [founderId], references: [id])

  leaderId String?     @db.ObjectId
  leader   Characters? @relation("OrganizationLeader", fields: [leaderId], references: [id])

  parentOrganizationId String?       @db.ObjectId
  parentOrganization   Organization? @relation("OrganizationHierarchy", fields: [parentOrganizationId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  subOrganizations Organization[] @relation("OrganizationHierarchy")

  foundedAt   WorldDate?
  dissolvedAt WorldDate?

  wars             WarParticipant[]
  members          CharacterOrganization[]
  historicalEvents OrganizationHistoricalEvent[]
  grantedTitles    CharacterTitle[]              @relation("TitleGrantedByOrganization")

  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  battleParticipants BattleParticipant[]
  grantedOccupations CharacterOccupation[] @relation("OccupationGrantedByOrganization")

  @@index([type])
  @@index([leaderId])
  @@index([founderId])
  @@index([parentOrganizationId])
}
