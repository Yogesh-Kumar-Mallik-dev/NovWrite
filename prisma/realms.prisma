model MajorRealm {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  path Cultivation_Path

  qiRealm   Qi_MajorRealm?
  bodyRealm Body_MajorRealm?
  soulRealm Soul_MajorRealm?

  power              Int?
  description        String?
  lifespan           Int?
  requiredEnergy     Int?
  breakthroughChance Float?

  minorRealms MinorRealm[]
  cultivation CharacterCultivation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MinorRealm {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  majorRealmId String @db.ObjectId

  majorRealm MajorRealm @relation(fields: [majorRealmId], references: [id], onDelete: Cascade)

  realm Minor_Realm

  power              Int?
  description        String?
  breakthroughChance Float?

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  characterCultivations CharacterCultivation[]

  @@unique([majorRealmId, realm])
}
