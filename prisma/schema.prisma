generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Elements {
  Fire
  Water
  Earth
  Wind
  Lightning
  Ice
}

enum Update {
  Edit
  Update
  Breakthrough
  Death
  Birth
  Rebirth
  Encounter
  Join_Faction
  Left_Faction
  Promotion
  Demotion
}

enum RelationshipType {
  Parent
  Child
  Elder_Brother
  Younger_Brother
  Elder_Sister
  Younger_Sister
  Sworn_Brother
  Sworn_Sister
  Senior_Brother
  Junior_Brother
  Senior_Sister
  Junior_Sister
  Martial_Aunt
  Martial_Uncle
  Grand_Father
  Grand_Mother
  Grand_Master
  Elder_Cousion_Brother
  Younger_Cousin_Brother
  Elder_Cousin_Sister
  Younger_Cousin_Sister
  Friend
  BestFriend
  Enemy
  Rival
  Lover
  Husband
  Wife
  Fiance
  Master
  Disciple
  Teacher
  Student
  Mentor
  Ally
  Servant
  Owner
  Pet
  ClanMember
  SectMember
  Ancestor
  Patriarch
  Matriarch
  Guardian
  Bodyguard
  Apprentice
  Twin
  Adoptive_Parent
  Adoptive_Child
  Marriage_Arranged
  Former_Lover
  Former_Master
  Former_Disciple
}

enum Qi_MajorRealm {
  Body_Tempering
  Qi_Refining
  Foundation_Establishment
  Golden_Core
  Nascent_Soul
  Soul_Transformation
  Body_Integration
  Tribulation_Transcendence
  Mahayana
  Immortal_Assension
}

enum Body_MajorRealm {
  Skin_Tempering
  Bone_Forging
  Viscera_Refining
  Blood_Condensation
  Rebirth
  Aura_Manifestation
  Void_Fusion
  Tribulation_Tempring
  Saintly_Being
  Void_Breaking
}

enum Soul_MajorRealm {
  Spiritual_Awakening
  Sense_Expansion
  Spirit_Condensation
  Soul_Manifastation
  Yin_Soul
  Yang_Soul
  Domain_Manifestation
  Tribunal_Soul
  Spiritual_Being
  Spirit_Assension
}

enum Minor_Realm {
  half_step
  one_star
  two_star
  three_star
  four_star
  five_star
  six_star
  seven_star
  eight_star
  nine_star
  peak
}

enum Grade {
  Mortal
  Common
  Rare
  Earth
  Heaven
  Spirit
  King
  Emperor
  Saint
  Divine
  Immortal
  Celestial
  Eternal
  Origin
  Transcendent
  Primordial
  Chaos
}

model Characters {
  id                String               @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  age               Int
  dateOfBirth       String?
  spiritRootId      String               @db.ObjectId
  spiritRoot        SpiritRoots          @relation(fields: [spiritRootId], references: [id])
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  relations         CharacterRelations[] @relation("SourceCharacter")
  relatedTo         CharacterRelations[] @relation("TargetCharacter")
  characterVersions CharacterVersion[]
}

model SpiritRoots {
  id                     String       @id @default(auto()) @map("_id") @db.ObjectId
  elements               Elements[]
  characters             Characters[]
  breakthroughMultiplier Int?
  basePowerMultiplier    Int?
  description            String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
}

model CharacterRelations {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  sourceCharacterId String           @db.ObjectId
  targetCharacterId String           @db.ObjectId
  relationshipType  RelationshipType
  startDate         String?
  endDate           String?
  description       String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  sourceCharacter   Characters       @relation("SourceCharacter", fields: [sourceCharacterId], references: [id])
  targetCharacter   Characters       @relation("TargetCharacter", fields: [targetCharacterId], references: [id])

  @@index([sourceCharacterId])
  @@index([targetCharacterId])
}

model QiMajorRealm {
  id                 String        @id @default(auto()) @map("_id") @db.ObjectId
  realm              Qi_MajorRealm
  power              Int?
  description        String?
  requiredQi         Int?
  lifespan           Int?
  breakthroughChance Float?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model CharacterVersion {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  characterId String     @db.ObjectId
  character   Characters @relation(fields: [characterId], references: [id])
  updateType  Update
  title       String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model BodyMajorRealm {
  id                 String           @id @default(auto()) @map("_id") @db.ObjectId
  realm              Body_MajorRealm?
  power              Int?
  description        String?
  requiredQi         Int?
  lifespan           Int?
  breakthroughChance Float?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Physique {
  id                          String   @id @default(auto()) @map("_id") @db.ObjectId
  name                        String
  grade                       Grade
  powerMultiplier             Int?
  breakthrough                Int?
  bodyRealmbreakthroughChance Int?
  QiRealmbreakthroughChance   Int?
  soulRealmbreakthroughChance Int?
  specialProperty             String?
  description                 String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}
