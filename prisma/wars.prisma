model War {
  id String @id @default(cuid())

  historicalEventId String          @unique
  historicalEvent   HistoricalEvent @relation(fields: [historicalEventId], references: [id])

  type    WarType
  outcome WarOutcome

  cause  String?
  result String?

  startedAt Json
  endedAt   Json?

  participants WarParticipant[]

  battles Battle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([outcome])
}

model WarParticipant {
  id String @id @default(cuid())

  warId String
  war   War    @relation(fields: [warId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  side Int

  role WarRole

  joinedAt Json?
  leftAt   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([warId, organizationId])
  @@index([warId])
  @@index([organizationId])
}
